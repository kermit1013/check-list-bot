# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
# 個人 User ID（U 開頭）或群組 Group ID（C 開頭）皆可
LINE_TARGET_ID=your_line_user_or_group_id_here

# App URL (update after Vercel deployment)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Upstash Redis (get from Upstash dashboard or Vercel Integration)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron job security secret (任意字串，Vercel Cron 會自動帶入)
CRON_SECRET=your_random_secret_here
